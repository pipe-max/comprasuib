rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Emails autorizados por rol ───
    function isAuthenticated() {
      return request.auth != null;
    }

    function userEmail() {
      return request.auth.token.email;
    }

    function isApprover() {
      return userEmail() in [
        'direccionadministrativa@uibmedellin.org',
        'rectoria@theodoro.edu.co',
        'gerencia@uibmedellin.org',
        'andresgonzalezcordoba@gmail.com',
        'contabilidad@uibmedellin.org',
        'pipe@theodoro.edu.co'
      ];
    }

    function canDelete() {
      return userEmail() in [
        'pipe@theodoro.edu.co',
        'direccionadministrativa@uibmedellin.org',
        'gerencia@uibmedellin.org',
        'analistatesoreria@uibmedellin.org',
        'analistacontable@theodoro.edu.co',
        'contabilidad@uibmedellin.org',
        'analistafinanciera@uibmedellin.org'
      ];
    }

    function isAllowedUser() {
      return isAuthenticated();
    }

    // ─── Órdenes ───
    match /orders/{orderId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated();
      // Solo aprobadores pueden cambiar status a 'approved'
      // Solo autorizados pueden eliminar (deleted: true)
      allow update: if isAuthenticated() && (
        (request.resource.data.status == 'approved' && isApprover()) ||
        (request.resource.data.get('deleted', false) == true && canDelete()) ||
        (request.resource.data.status != 'approved' && request.resource.data.get('deleted', false) == false)
      );
      allow delete: if canDelete();
    }

    match /config/{docId} {
      allow read, write: if isAuthenticated();
    }

    match /providers/{providerId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    match /fcmTokens/{email} {
      allow read, write: if isAuthenticated();
    }

    match /notifications/{notifId} {
      allow read, write: if isAuthenticated();
    }
  }
}
