rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /orders/{orderId} {
      allow read, write: if request.auth != null;
    }
    match /config/{docId} {
      allow read, write: if request.auth != null;
    }
    match /providers/{providerId} {
      allow read, write: if request.auth != null;
    }
    match /fcmTokens/{email} {
      allow read, write: if request.auth != null;
    }
    match /notifications/{notifId} {
      allow read, write: if request.auth != null;
    }
  }
}
